# ========== Front (Vite) — pode repetir no Vercel com prefixo VITE_ ==========
# Supabase → Dashboard do projeto → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# URL pública do app (links / redirects). Em dev costuma ser desnecessário.
VITE_APP_BASE_URL=

# Suporte / renovação PIX (texto nas mensagens)
VITE_AGENDAFACIL_PIX_KEY=
VITE_RENEWAL_REMINDER_WINDOW_DAYS=
VITE_DEFAULT_BILLING_CYCLE_DAYS=

# WhatsApp via Supabase Edge Function (recomendado) ou outro POST { phone, text }
# URL típica: https://<PROJECT_REF>.supabase.co/functions/v1/whatsapp-send
VITE_WHATSAPP_EDGE_URL=
# Mesmo valor do secret WHATSAPP_EDGE_AUTH_TOKEN na função (header x-agenda-facil-proxy-secret). Obrigatório se a função exigir.
VITE_WHATSAPP_EDGE_TOKEN=
# Idioma padrão dos templates aprovados na Meta.
VITE_WHATSAPP_TEMPLATE_LANG=pt_BR
# Templates opcionais para automações WhatsApp.
# A função envia 7 parâmetros de corpo nesta ordem:
# 1) primeiro nome do cliente
# 2) nome do negócio
# 3) data formatada
# 4) horário formatado
# 5) serviço
# 6) profissional
# 7) valor
VITE_WHATSAPP_CONFIRM_TEMPLATE_NAME=
VITE_WHATSAPP_CONFIRM_TEMPLATE_LANG=pt_BR
VITE_WHATSAPP_CANCEL_TEMPLATE_NAME=
VITE_WHATSAPP_RESCHEDULE_TEMPLATE_NAME=
# Lembrete D-1 (ordem: cliente, negócio, serviço, horário, profissional)
VITE_WHATSAPP_DAYBEFORE_TEMPLATE_NAME=
# Cobrança PIX (ordem: loja, plano, valor, vencimento, chave PIX)
VITE_WHATSAPP_RENEWAL_TEMPLATE_NAME=
# Trial acabando / escolha de plano (ordem: nome/loja, dias restantes, starter, pro)
VITE_WHATSAPP_TRIAL_END_TEMPLATE_NAME=

# ========== Vercel (Environment Variables) ==========
# Já comuns: SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY
#
# Cron lembretes D-1 (gerar com: openssl rand -hex 32)
# CRON_SECRET=
#
# Mesma URL da função whatsapp-send + mesmo segredo do proxy (opcional na função)
# WHATSAPP_EDGE_URL=https://xxxx.supabase.co/functions/v1/whatsapp-send
# WHATSAPP_EDGE_TOKEN=<igual WHATSAPP_EDGE_AUTH_TOKEN no Supabase>
#
# Opcional no cron se não usar service role no Authorization da função:
# SUPABASE_ANON_KEY=

# ========== Etapa 5 — Meta WhatsApp Cloud API + Supabase Edge ==========
#
# 1) Meta for Developers (https://developers.facebook.com/)
#    - Crie um app → tipo "Business" → produto WhatsApp.
#    - Em WhatsApp → API de teste ou número de produção: copie
#      • Token de acesso (Access Token) → use como WHATSAPP_ACCESS_TOKEN na função
#      • ID do número de telefone (Phone number ID) → WHATSAPP_PHONE_NUMBER_ID
#    - O número de destino do cliente precisa estar na lista de teste até o app ser aprovado.
#
# 2) Supabase CLI (https://supabase.com/docs/guides/functions)
#    supabase login
#    supabase link --project-ref <PROJECT_REF>
#    supabase secrets set WHATSAPP_ACCESS_TOKEN="..." WHATSAPP_PHONE_NUMBER_ID="..." WHATSAPP_EDGE_AUTH_TOKEN="$(openssl rand -hex 24)"
#    supabase functions deploy whatsapp-send
#    (verify_jwt = false já está em supabase/config.toml para esta função)
#
# 3) Copie a URL da função (Project Settings → Edge Functions ou log do deploy) para:
#    - Vercel: WHATSAPP_EDGE_URL e VITE_WHATSAPP_EDGE_URL
#    - VITE_WHATSAPP_EDGE_TOKEN e WHATSAPP_EDGE_TOKEN = valor de WHATSAPP_EDGE_AUTH_TOKEN
#
# 4) Na Vercel, mantenha SUPABASE_SERVICE_ROLE_KEY: o cron usa Bearer service_role + x-agenda-facil-proxy-secret.

# ========== Teste com curl (após deploy da função) ==========
# Troque PROJECT_REF, SUA_ANON_KEY, SEU_SEGREDO_PROXY e o telefone (lista de testes da Meta, se em modo teste).
#
# Com WHATSAPP_EDGE_AUTH_TOKEN definido no Supabase (recomendado):
#
# curl -sS -X POST "https://PROJECT_REF.supabase.co/functions/v1/whatsapp-send" \
#   -H "Authorization: Bearer SUA_ANON_KEY" \
#   -H "x-agenda-facil-proxy-secret: SEU_SEGREDO_PROXY" \
#   -H "Content-Type: application/json" \
#   -d '{"phone":"5511999999999","text":"Teste Agenda Fácil — mensagem via Edge Function."}'
#
# Se você NÃO definiu WHATSAPP_EDGE_AUTH_TOKEN na função, omita o header x-agenda-facil-proxy-secret:
#
# curl -sS -X POST "https://PROJECT_REF.supabase.co/functions/v1/whatsapp-send" \
#   -H "Authorization: Bearer SUA_ANON_KEY" \
#   -H "Content-Type: application/json" \
#   -d '{"phone":"5511999999999","text":"Teste sem proxy secret."}'
#
# Resposta esperada em sucesso: JSON com "ok": true e payload da Meta. Erro 401 = segredo proxy errado ou ausente.
# Erro 502 com "Meta API" = token Meta, Phone ID ou número de destino inválido / fora da lista de teste.
