{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "crons": [
    {
      "path": "/api/cron/appointment-reminders",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/trial-ending-reminders",
      "schedule": "15 13 * * *"
    }
  ],
  "rewrites": [{ "source": "/((?!assets/)(?!api/).*)", "destination": "/index.html" }]
}
